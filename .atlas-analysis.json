  "keyFeatures": [
    "Advanced Paste - Enhanced clipboard management with AI-powered transformations",
    "FancyZones - Advanced window layout manager for organizing applications",
    "PowerToys Run - Quick launcher for applications, files, and commands",
    "Color Picker - System-wide color picker utility with history",
    "Keyboard Manager - Remap keys and create custom keyboard shortcuts",
    "PowerRename - Bulk file renaming with regex support",
    "Image Resizer - Batch resize images from context menu",
    "File Locksmith - Find which processes are using a file",
    "Text Extractor - Extract text from images using OCR",
    "Mouse Utilities - Find My Mouse, Mouse Highlighter, Mouse Jump, and Crosshairs",
    "Peek - Quick file preview with spacebar",
    "Command Palette - Universal command launcher with extensibility",
    "Workspaces - Save and restore application layouts",
    "Always on Top - Pin windows to stay on top",
    "Awake - Keep computer awake without changing power settings",
    "Hosts File Editor - Easily edit the Windows hosts file",
    "Registry Preview - Visualize registry file changes",
    "Screen Ruler - Measure pixels on screen",
    "Shortcut Guide - Display Windows keyboard shortcuts",
    "Mouse Without Borders - Control multiple computers with one mouse and keyboard",
    "ZoomIt - Screen zoom and annotation tool",
    "Quick Accent - Type accented characters easily",
    "New+ - Create new files from templates via context menu",
    "Crop and Lock - Crop windows to specific regions",
    "Light Switch - Toggle between light and dark themes"
  ],
